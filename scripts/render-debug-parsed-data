#!/usr/bin/env python3
"""Render parsed Idleon example data for local debugging."""

from __future__ import annotations

import argparse
import dataclasses
import html
import json
import os
import sys
import time
from collections.abc import Iterable, Mapping
from datetime import datetime
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
VENV_PYTHON = ROOT / ".venv/bin/python"
if VENV_PYTHON.exists() and Path(sys.executable) != VENV_PYTHON:
    os.execv(VENV_PYTHON, [str(VENV_PYTHON), *sys.argv])

sys.path.insert(0, str(ROOT))

from custom_components.idleon.idleon_data import (  # noqa: E402
    parse_all_toolbox_sections,
    parse_idleon_account,
)
from custom_components.idleon.idleon_data.game_maps import (  # noqa: E402
    class_name_label,
    display_name,
)
from custom_components.idleon.models import IdleonAccount  # noqa: E402

DEFAULT_INPUT_GLOBS = ("examples/rawData.json", "examples/real_data*.json")
DEFAULT_CLEAN_REFERENCE = ROOT / "examples/cleanData.json"
DEFAULT_OUTPUT_DIR = ROOT / "debug"
RENDERER_VERSION = "clean-reference-class-labels-v2"


def main() -> int:
    """Render local debug output for parsed Idleon example data."""
    parser = argparse.ArgumentParser(
        description="Render parsed HA Idleon data from local example JSON files.",
    )
    parser.add_argument(
        "paths",
        nargs="*",
        type=Path,
        help="Input JSON files. Defaults to examples/rawData.json and real_data*.json.",
    )
    parser.add_argument(
        "--clean-reference",
        type=Path,
        default=DEFAULT_CLEAN_REFERENCE,
        help="Optional cleanData.json reference to show beside parsed output.",
    )
    parser.add_argument(
        "--output-dir",
        type=Path,
        default=DEFAULT_OUTPUT_DIR,
        help="Directory for parsed-data.json and parsed-data.html.",
    )
    parser.add_argument(
        "--watch",
        action="store_true",
        help="Regenerate debug output when parser or example files change.",
    )
    parser.add_argument(
        "--poll-interval",
        type=float,
        default=1.0,
        help="Seconds between file checks in watch mode.",
    )
    parser.add_argument(
        "--html-refresh",
        type=int,
        default=2,
        help="Browser refresh interval, in seconds, for watch-mode HTML output.",
    )
    args = parser.parse_args()

    input_paths = tuple(args.paths) or _default_input_paths()
    if not input_paths:
        patterns = ", ".join(DEFAULT_INPUT_GLOBS)
        sys.stderr.write(f"No input files found for {patterns}\n")
        return 1

    if args.watch:
        return _watch(
            input_paths=input_paths,
            clean_reference_path=args.clean_reference,
            output_dir=args.output_dir,
            poll_interval=args.poll_interval,
            html_refresh=args.html_refresh,
        )

    _render_debug_files(
        input_paths=input_paths,
        clean_reference_path=args.clean_reference,
        output_dir=args.output_dir,
    )
    return 0


def _render_debug_files(
    *,
    input_paths: tuple[Path, ...],
    clean_reference_path: Path,
    output_dir: Path,
    html_refresh: int | None = None,
) -> None:
    """Render JSON and HTML debug files once."""
    clean_reference = _load_clean_reference(clean_reference_path)
    rendered = [_render_source(path, clean_reference) for path in input_paths]
    output_dir.mkdir(parents=True, exist_ok=True)

    json_path = output_dir / "parsed-data.json"
    html_path = output_dir / "parsed-data.html"
    json_path.write_text(json.dumps(rendered, indent=2) + "\n")
    html_path.write_text(_render_html(rendered, refresh_seconds=html_refresh))

    sys.stdout.write(f"Wrote {json_path}\n")
    sys.stdout.write(f"Wrote {html_path}\n")


def _watch(
    *,
    input_paths: tuple[Path, ...],
    clean_reference_path: Path,
    output_dir: Path,
    poll_interval: float,
    html_refresh: int,
) -> int:
    """Watch parser and example files, then regenerate debug output."""
    sys.stdout.write("Watching Idleon parser inputs. Press Ctrl+C to stop.\n")
    watched_paths = _watch_paths(input_paths, clean_reference_path)
    last_snapshot: dict[Path, float | None] = {}

    try:
        while True:
            snapshot = _mtime_snapshot(watched_paths)
            if last_snapshot and _code_changed(last_snapshot, snapshot):
                sys.stdout.write("Parser code changed; restarting debug watch.\n")
                os.execv(sys.executable, [sys.executable, *sys.argv])
            if snapshot != last_snapshot:
                _render_debug_files(
                    input_paths=input_paths,
                    clean_reference_path=clean_reference_path,
                    output_dir=output_dir,
                    html_refresh=html_refresh,
                )
                last_snapshot = snapshot
            time.sleep(poll_interval)
    except KeyboardInterrupt:
        sys.stdout.write("Stopped debug watch.\n")
        return 0


def _watch_paths(
    input_paths: tuple[Path, ...],
    clean_reference_path: Path,
) -> tuple[Path, ...]:
    """Return files that should trigger debug regeneration."""
    paths: list[Path] = [*input_paths, clean_reference_path]
    paths.extend((ROOT / "custom_components/idleon").rglob("*.py"))
    paths.extend((ROOT / "tests/fixtures").glob("*.json"))
    paths.append(Path(__file__))
    return tuple(dict.fromkeys(path.resolve() for path in paths))


def _mtime_snapshot(paths: tuple[Path, ...]) -> dict[Path, float | None]:
    """Return file mtimes for watch comparisons."""
    snapshot: dict[Path, float | None] = {}
    for path in paths:
        try:
            snapshot[path] = path.stat().st_mtime
        except FileNotFoundError:
            snapshot[path] = None
    return snapshot


def _code_changed(
    previous: Mapping[Path, float | None],
    current: Mapping[Path, float | None],
) -> bool:
    """Return whether watched Python code changed and requires reload."""
    for path, current_mtime in current.items():
        if path.suffix != ".py" and path.name != Path(__file__).name:
            continue
        if previous.get(path) != current_mtime:
            return True
    return False


def _default_input_paths() -> tuple[Path, ...]:
    """Return default local raw export paths."""
    paths: list[Path] = []
    for pattern in DEFAULT_INPUT_GLOBS:
        paths.extend(sorted(ROOT.glob(pattern)))
    return tuple(dict.fromkeys(paths))


def _render_source(
    path: Path,
    clean_reference: Mapping[str, Any] | None,
) -> dict[str, Any]:
    """Return parsed debug output for one source file."""
    raw_data = _load_json(path)
    account = parse_idleon_account(raw_data)
    toolbox_sections = _toolbox_sections_summary(raw_data)
    rendered = {
        "source": str(path),
        "generated_at": datetime.now().isoformat(timespec="seconds"),
        "renderer_version": RENDERER_VERSION,
        "raw_summary": _raw_summary(raw_data),
        "parsed": _account_to_dict(account),
        "toolbox_summary": _toolbox_summary(toolbox_sections),
        "toolbox_sections": toolbox_sections,
    }
    if clean_reference is not None:
        rendered["clean_reference"] = _clean_reference_summary(clean_reference)
    return rendered


def _load_json(path: Path) -> Mapping[str, Any]:
    """Load one JSON object from disk."""
    raw_data = json.loads(path.read_text())
    if not isinstance(raw_data, Mapping):
        msg = f"{path}: expected top-level JSON object"
        raise TypeError(msg)
    return raw_data


def _load_clean_reference(path: Path) -> Mapping[str, Any] | None:
    """Load optional clean parsed reference data."""
    if not path.exists():
        return None
    return _load_json(path)


def _clean_reference_summary(clean_data: Mapping[str, Any]) -> dict[str, Any]:
    """Return the relevant parsed fields from cleanData.json."""
    characters = clean_data.get("characters")
    if not isinstance(characters, list):
        characters = []
    clean_characters = [
        _clean_character_summary(character)
        for character in characters
        if isinstance(character, Mapping)
    ]
    return {
        "account": {
            "character_count": len(clean_characters),
            "total_level": sum(
                _coerce_int(character.get("level")) or 0
                for character in clean_characters
            ),
        },
        "characters": clean_characters,
    }


def _clean_character_summary(character: Mapping[str, Any]) -> dict[str, Any]:
    """Return cleanData character fields relevant to current HA entities."""
    inventory = character.get("inventory")
    return {
        "name": character.get("name"),
        "level": character.get("level"),
        "class": _clean_class_label(character.get("class")),
        "raw_class": character.get("class"),
        "currentMap": character.get("currentMap"),
        "AFKtarget": character.get("AFKtarget"),
        "timeAway": character.get("timeAway"),
        "inventory_slots": len(inventory) if isinstance(inventory, list) else None,
    }


def _clean_class_label(value: Any) -> str | None:
    """Return a clean reference class display label."""
    if value is None:
        return None
    class_id = _coerce_int(value)
    if class_id is not None:
        return class_name_label(class_id)
    return display_name(str(value))


def _coerce_int(value: Any) -> int | None:
    """Return value coerced to int when possible."""
    try:
        return int(value)
    except TypeError:
        return None
    except ValueError:
        return None


def _raw_summary(raw_data: Mapping[str, Any]) -> dict[str, Any]:
    """Return a private-data-light summary of raw input shape."""
    fields = _indexed_export_fields(raw_data)
    indexed_fields = _indexed_field_counts(fields)
    return {
        "top_level_key_count": len(raw_data),
        "field_count": len(fields),
        "wrapped_save_data": fields is not raw_data,
        "char_name_count": _char_name_count(raw_data),
        "indexed_character_count": len(_indexed_character_ids(fields)),
        "indexed_field_counts": indexed_fields,
    }


def _toolbox_sections_summary(raw_data: Mapping[str, Any]) -> dict[str, Any]:
    """Return metadata-mode Toolbox parser section summaries."""
    sections = parse_all_toolbox_sections(raw_data)
    return {
        parser_id: {
            "source_path": section.source_path,
            "status": section.status,
            "functions": section.functions,
            "website_data": section.website_data,
            "matched_raw_fields": tuple(section.raw_fields),
            "missing_raw_fields": section.missing_raw_fields,
        }
        for parser_id, section in sections.items()
    }


def _toolbox_summary(toolbox_sections: Mapping[str, Any]) -> dict[str, Any]:
    """Return compact Toolbox parser coverage counts."""
    matched_count = sum(
        1 for section in toolbox_sections.values() if section.get("matched_raw_fields")
    )
    return {
        "parser_section_count": len(toolbox_sections),
        "sections_with_matched_raw_fields": matched_count,
    }


def _indexed_export_fields(raw_data: Mapping[str, Any]) -> Mapping[str, Any]:
    """Return raw fields from flat or wrapped exports."""
    save_data = raw_data.get("saveData")
    if isinstance(save_data, Mapping):
        return save_data
    return raw_data


def _char_name_count(raw_data: Mapping[str, Any]) -> int:
    """Return the number of wrapped character names."""
    char_names = raw_data.get("charNameData")
    if isinstance(char_names, Iterable) and not isinstance(char_names, str | bytes):
        return len(tuple(char_names))
    return 0


def _indexed_field_counts(raw_data: Mapping[str, Any]) -> dict[str, int]:
    """Return counts for key indexed fields without dumping raw values."""
    prefixes = (
        "CharacterClass",
        "PVStatList",
        "Lv0",
        "CurrentMap",
        "AFKtarget",
        "PTimeAway",
        "InventoryOrder",
    )
    return {
        prefix: sum(1 for key in raw_data if key.startswith(f"{prefix}_"))
        for prefix in prefixes
    }


def _indexed_character_ids(raw_data: Mapping[str, Any]) -> set[int]:
    """Return indexed character IDs found in raw export fields."""
    indexes: set[int] = set()
    for key in raw_data:
        for prefix in ("CharacterClass_", "PVStatList_", "Lv0_", "CurrentMap_"):
            if not key.startswith(prefix):
                continue
            try:
                indexes.add(int(key.removeprefix(prefix)))
            except ValueError:
                continue
    return indexes


def _account_to_dict(account: IdleonAccount) -> dict[str, Any]:
    """Return a JSON-serializable parsed account model."""
    data = dataclasses.asdict(account)
    data["character_count"] = account.character_count
    return _json_safe(data)


def _json_safe(value: Any) -> Any:
    """Return a JSON-safe representation of dataclass values."""
    if isinstance(value, datetime):
        return value.isoformat()
    if isinstance(value, Mapping):
        return {str(key): _json_safe(item) for key, item in value.items()}
    if isinstance(value, tuple | list):
        return [_json_safe(item) for item in value]
    return value


def _render_html(
    rendered: list[dict[str, Any]],
    *,
    refresh_seconds: int | None = None,
) -> str:
    """Return a standalone HTML debug report."""
    sections = "\n".join(_render_source_section(source) for source in rendered)
    payload = html.escape(json.dumps(rendered, indent=2))
    refresh_tag = (
        f'  <meta http-equiv="refresh" content="{refresh_seconds}">\n'
        if refresh_seconds
        else ""
    )
    return f"""<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
{refresh_tag}  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>HA Idleon Parsed Data Debug</title>
  <style>
    body {{
      background: #f7f8fa;
      color: #1f2933;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.5;
      margin: 0;
      padding: 32px;
    }}
    main {{
      margin: 0 auto;
      max-width: 1180px;
    }}
    h1, h2, h3 {{
      line-height: 1.2;
    }}
    section {{
      background: #ffffff;
      border: 1px solid #d9e2ec;
      border-radius: 8px;
      margin: 20px 0;
      padding: 20px;
    }}
    table {{
      border-collapse: collapse;
      margin: 12px 0;
      width: 100%;
    }}
    th, td {{
      border-bottom: 1px solid #edf2f7;
      padding: 8px 10px;
      text-align: left;
      vertical-align: top;
    }}
    th {{
      background: #f0f4f8;
      font-weight: 600;
    }}
    code, pre {{
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-size: 13px;
    }}
    pre {{
      background: #102a43;
      border-radius: 8px;
      color: #f0f4f8;
      overflow: auto;
      padding: 16px;
    }}
    .muted {{
      color: #627d98;
    }}
  </style>
</head>
<body>
  <main>
    <h1>HA Idleon Parsed Data Debug</h1>
    <p class="muted">
      Local debug output from the current parser. Treat this file as private if
      it was generated from real Idleon account exports.
    </p>
    {sections}
    <section>
      <h2>Full Parsed JSON</h2>
      <pre>{payload}</pre>
    </section>
  </main>
</body>
</html>
"""


def _render_source_section(source: dict[str, Any]) -> str:
    """Return one HTML source section."""
    parsed = source["parsed"]
    raw_summary = source["raw_summary"]
    debug_metadata = {
        "generated_at": source["generated_at"],
        "renderer_version": source["renderer_version"],
        **source["toolbox_summary"],
    }
    toolbox_sections = source["toolbox_sections"]
    characters = parsed["characters"]
    character_rows = "\n".join(
        _render_character_row(character) for character in characters
    )
    summary_rows = "\n".join(
        _render_key_value_row(key, value) for key, value in raw_summary.items()
    )
    debug_metadata_rows = "\n".join(
        _render_key_value_row(key, value) for key, value in debug_metadata.items()
    )
    account_rows = "\n".join(
        _render_key_value_row(key, value)
        for key, value in parsed.items()
        if key != "characters"
    )
    clean_reference = source.get("clean_reference")
    clean_html = ""
    if isinstance(clean_reference, Mapping):
        clean_html = _render_clean_reference(clean_reference)
    toolbox_html = _render_toolbox_sections(toolbox_sections)
    return f"""<section>
  <h2>{html.escape(source["source"])}</h2>
  <h3>Debug Metadata</h3>
  <table>
    <tbody>
      {debug_metadata_rows}
    </tbody>
  </table>
  <h3>Account</h3>
  <table>
    <tbody>
      {account_rows}
    </tbody>
  </table>
  <h3>Characters</h3>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Level</th>
        <th>Class</th>
        <th>Map</th>
        <th>Activity</th>
        <th>AFK Hours</th>
        <th>Inventory Full</th>
        <th>Needs Attention</th>
      </tr>
    </thead>
    <tbody>
      {character_rows}
    </tbody>
  </table>
  <h3>Raw Shape Summary</h3>
  <table>
    <tbody>
      {summary_rows}
    </tbody>
  </table>
  {toolbox_html}
  {clean_html}
</section>"""


def _render_toolbox_sections(toolbox_sections: Mapping[str, Any]) -> str:
    """Return a compact Toolbox parser coverage table."""
    rows = "\n".join(
        _render_toolbox_section_row(parser_id, section)
        for parser_id, section in toolbox_sections.items()
    )
    return f"""<h3>IdleonToolbox Parser Sections</h3>
  <table>
    <thead>
      <tr>
        <th>Parser</th>
        <th>Website Data</th>
        <th>Matched Raw Fields</th>
        <th>Missing Raw Fields</th>
      </tr>
    </thead>
    <tbody>
      {rows}
    </tbody>
  </table>"""


def _render_toolbox_section_row(parser_id: str, section: Mapping[str, Any]) -> str:
    """Return one Toolbox parser coverage row."""
    return f"""<tr>
  <td><code>{html.escape(parser_id)}</code></td>
  <td>{html.escape(_join_values(section.get("website_data")))}</td>
  <td>{html.escape(_join_values(section.get("matched_raw_fields")))}</td>
  <td>{html.escape(_join_values(section.get("missing_raw_fields")))}</td>
</tr>"""


def _join_values(value: Any) -> str:
    """Return a compact comma-separated display value."""
    if isinstance(value, Iterable) and not isinstance(value, str | bytes):
        values = [str(item) for item in value]
        if len(values) > 8:
            return f"{', '.join(values[:8])}, ..."
        return ", ".join(values)
    if value is None:
        return ""
    return str(value)


def _render_clean_reference(clean_reference: Mapping[str, Any]) -> str:
    """Return clean parsed reference HTML."""
    account = clean_reference.get("account")
    characters = clean_reference.get("characters")
    if not isinstance(account, Mapping) or not isinstance(characters, list):
        return ""

    account_rows = "\n".join(
        _render_key_value_row(key, value) for key, value in account.items()
    )
    character_rows = "\n".join(
        _render_clean_character_row(character)
        for character in characters
        if isinstance(character, Mapping)
    )
    return f"""<h3>Clean Reference</h3>
  <table>
    <tbody>
      {account_rows}
    </tbody>
  </table>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Level</th>
        <th>Class</th>
        <th>Raw Class</th>
        <th>Current Map ID</th>
        <th>AFK Target</th>
        <th>Time Away</th>
        <th>Inventory Slots</th>
      </tr>
    </thead>
    <tbody>
      {character_rows}
    </tbody>
  </table>"""


def _render_clean_character_row(character: Mapping[str, Any]) -> str:
    """Return one clean reference character table row."""
    cells = (
        character.get("name"),
        character.get("level"),
        character.get("class"),
        character.get("raw_class"),
        character.get("currentMap"),
        character.get("AFKtarget"),
        character.get("timeAway"),
        character.get("inventory_slots"),
    )
    return (
        "<tr>"
        + "".join(f"<td>{html.escape(str(cell))}</td>" for cell in cells)
        + "</tr>"
    )


def _render_character_row(character: Mapping[str, Any]) -> str:
    """Return one character table row."""
    cells = (
        character["character_id"],
        character["name"],
        character["level"],
        character["character_class"],
        character["current_map"],
        character["current_activity"],
        character["afk_hours"],
        character["inventory_full"],
        character["needs_attention"],
    )
    return (
        "<tr>"
        + "".join(f"<td>{html.escape(str(cell))}</td>" for cell in cells)
        + "</tr>"
    )


def _render_key_value_row(key: str, value: Any) -> str:
    """Return one key/value table row."""
    if isinstance(value, Mapping | list):
        rendered_value = json.dumps(value, indent=2)
    else:
        rendered_value = str(value)
    return (
        "<tr>"
        f"<th>{html.escape(str(key))}</th>"
        f"<td><code>{html.escape(rendered_value)}</code></td>"
        "</tr>"
    )


if __name__ == "__main__":
    raise SystemExit(main())
