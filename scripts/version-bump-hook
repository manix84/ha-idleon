#!/usr/bin/env python3
"""Smart commit-time version bumping for HA Idleon."""

from __future__ import annotations

import os
import re
import subprocess
import sys
import tomllib
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
VERSION_FILES = (
    Path("pyproject.toml"),
    Path("custom_components/idleon/manifest.json"),
    Path("custom_components/idleon/const.py"),
    Path("README.md"),
    Path("WHATSNEW.md"),
)
DOC_ONLY_PREFIXES = (
    ".github/ISSUE_TEMPLATE/",
    "assets/",
    "docs/",
)
DOC_ONLY_FILES = {
    ".gitignore",
    "AI_DECLARATION.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "PRIVACY.md",
    "README.md",
    "SECURITY.md",
    "SUPPORT.md",
    "THIRD_PARTY_NOTICES.md",
    "WHATSNEW.md",
    "hacs.json",
}
MINOR_PREFIXES = ("custom_components/idleon/translations/",)
MINOR_FILES = {
    "custom_components/idleon/binary_sensor.py",
    "custom_components/idleon/config_flow.py",
    "custom_components/idleon/const.py",
    "custom_components/idleon/manifest.json",
    "custom_components/idleon/models.py",
    "custom_components/idleon/sensor.py",
    "custom_components/idleon/strings.json",
}


def main() -> int:
    """Bump version files based on staged changes."""
    override = os.environ.get("HA_IDLEON_VERSION_BUMP", "auto").lower()
    if override not in {"auto", "minor", "patch", "skip"}:
        sys.stderr.write(
            "HA_IDLEON_VERSION_BUMP must be one of: auto, minor, patch, skip\n"
        )
        return 2

    changed_files = _staged_files()
    bump = _select_bump(changed_files, override)
    if bump == "skip":
        return 0

    current_version = _project_version()
    new_version = _bump_version(current_version, bump)
    commit_message_path = Path(sys.argv[1]) if len(sys.argv) > 1 else None
    release_notes = _release_notes(commit_message_path, bump)
    _write_version_files(current_version, new_version, release_notes)
    _git_add(VERSION_FILES)
    sys.stderr.write(
        f"HA Idleon version bumped {current_version} -> {new_version} ({bump}).\n"
    )
    return 0


def _staged_files() -> tuple[Path, ...]:
    """Return paths staged for commit."""
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=ACMR"],
        cwd=ROOT,
        check=True,
        capture_output=True,
        text=True,
    )
    return tuple(Path(line) for line in result.stdout.splitlines() if line)


def _select_bump(changed_files: tuple[Path, ...], override: str) -> str:
    """Select a semver bump from staged files."""
    if override != "auto":
        return override

    relevant_files = [path for path in changed_files if path not in VERSION_FILES]
    if not relevant_files:
        return "skip"

    if _version_already_staged():
        return "skip"

    if all(_is_doc_only_file(path) for path in relevant_files):
        return "skip"

    if any(_is_minor_file(path) for path in relevant_files):
        return "minor"

    return "patch"


def _is_doc_only_file(path: Path) -> bool:
    """Return whether a path should not trigger a release bump."""
    path_text = path.as_posix()
    if path_text in DOC_ONLY_FILES:
        return True
    if any(path_text.startswith(prefix) for prefix in DOC_ONLY_PREFIXES):
        return True
    return path.suffix.lower() in {".md", ".png", ".jpg", ".jpeg", ".gif", ".svg"}


def _is_minor_file(path: Path) -> bool:
    """Return whether a path changes the public integration surface."""
    path_text = path.as_posix()
    if path_text in MINOR_FILES:
        return True
    return any(path_text.startswith(prefix) for prefix in MINOR_PREFIXES)


def _project_version() -> str:
    """Return the current project version."""
    pyproject = tomllib.loads((ROOT / "pyproject.toml").read_text())
    return str(pyproject["project"]["version"])


def _version_already_staged() -> bool:
    """Return whether a version bump is already staged."""
    result = subprocess.run(
        ["git", "show", "HEAD:pyproject.toml"],
        cwd=ROOT,
        check=False,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return False

    head_pyproject = tomllib.loads(result.stdout)
    head_version = str(head_pyproject["project"]["version"])
    return _project_version() != head_version


def _bump_version(version: str, bump: str) -> str:
    """Return a bumped semantic version."""
    match = re.fullmatch(r"(\d+)\.(\d+)\.(\d+)", version)
    if not match:
        msg = f"Unsupported version format: {version}"
        raise ValueError(msg)

    major, minor, patch = (int(part) for part in match.groups())
    if bump == "minor":
        return f"{major}.{minor + 1}.0"
    if bump == "patch":
        return f"{major}.{minor}.{patch + 1}"

    msg = f"Unsupported bump type: {bump}"
    raise ValueError(msg)


def _write_version_files(
    current_version: str,
    new_version: str,
    release_notes: tuple[str, ...],
) -> None:
    """Update version files in place."""
    _replace_text(
        Path("pyproject.toml"),
        f'version = "{current_version}"',
        f'version = "{new_version}"',
    )
    _replace_text(
        Path("custom_components/idleon/const.py"),
        f'VERSION = "{current_version}"',
        f'VERSION = "{new_version}"',
    )
    _replace_text(
        Path("README.md"),
        f"version-{current_version}-blue",
        f"version-{new_version}-blue",
    )
    _replace_text(
        Path("README.md"),
        f"Version {current_version}",
        f"Version {new_version}",
    )
    _update_manifest(current_version, new_version)
    _update_whatsnew(new_version, release_notes)


def _replace_text(path: Path, before: str, after: str) -> None:
    """Replace required text in a file."""
    file_path = ROOT / path
    text = file_path.read_text()
    if before not in text:
        msg = f"{path}: expected text not found: {before}"
        raise RuntimeError(msg)
    file_path.write_text(text.replace(before, after, 1))


def _update_manifest(current_version: str, new_version: str) -> None:
    """Update manifest version while preserving existing JSON formatting."""
    _replace_text(
        Path("custom_components/idleon/manifest.json"),
        f'"version": "{current_version}"',
        f'"version": "{new_version}"',
    )


def _update_whatsnew(new_version: str, release_notes: tuple[str, ...]) -> None:
    """Add a What's New section for the bumped version."""
    path = ROOT / "WHATSNEW.md"
    text = path.read_text()
    heading = f"## 🚀 {new_version}"
    if heading in text:
        return

    body = "\n".join(f"- {note}" for note in release_notes)
    insert = f"{heading}\n\n{body}\n\n"
    marker = "## 🚀 "
    marker_index = text.find(marker)
    if marker_index == -1:
        path.write_text(f"{text.rstrip()}\n\n{insert}")
        return

    path.write_text(f"{text[:marker_index]}{insert}{text[marker_index:]}")


def _release_notes(
    commit_message_path: Path | None,
    bump: str,
) -> tuple[str, ...]:
    """Return generated release notes for a version bump."""
    env_note = os.environ.get("HA_IDLEON_RELEASE_NOTE", "").strip()
    if env_note:
        return (_release_note_sentence(env_note),)

    if commit_message_path is not None:
        notes = _release_notes_from_commit_message(commit_message_path)
        if notes:
            return notes

    return (_release_note_sentence(f"{bump.title()} release"),)


def _release_notes_from_commit_message(path: Path) -> tuple[str, ...]:
    """Return release notes from a commit message file."""
    message_path = path if path.is_absolute() else ROOT / path
    if not message_path.exists():
        return ()

    lines = _commit_message_lines(message_path.read_text())
    if not lines:
        return ()

    body_bullets = [
        _release_note_sentence(line[2:].strip())
        for line in lines[1:]
        if line.startswith(("- ", "* ")) and line[2:].strip()
    ]
    if body_bullets:
        return tuple(body_bullets)

    return (_release_note_sentence(_strip_conventional_commit_prefix(lines[0])),)


def _commit_message_lines(message: str) -> tuple[str, ...]:
    """Return meaningful non-comment commit message lines."""
    lines: list[str] = []
    for line in message.splitlines():
        stripped = line.strip()
        if stripped == "# ------------------------ >8 ------------------------":
            break
        if not stripped or stripped.startswith("#"):
            continue
        lines.append(stripped)
    return tuple(lines)


def _strip_conventional_commit_prefix(subject: str) -> str:
    """Return a subject without a conventional-commit prefix."""
    return re.sub(
        r"^(?:build|chore|ci|docs|feat|fix|perf|refactor|test)"
        r"(?:\([^)]+\))?!?:\s+",
        "",
        subject,
        flags=re.IGNORECASE,
    ).strip()


def _release_note_sentence(value: str) -> str:
    """Return one readable release note sentence."""
    note = value.strip()
    if not note:
        return "Release update."
    note = note[0].upper() + note[1:]
    if note[-1] not in ".!?":
        note = f"{note}."
    return note


def _git_add(paths: tuple[Path, ...]) -> None:
    """Stage changed version files."""
    subprocess.run(
        ["git", "add", *(path.as_posix() for path in paths)],
        cwd=ROOT,
        check=True,
    )


if __name__ == "__main__":
    raise SystemExit(main())
