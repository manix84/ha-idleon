#!/usr/bin/env python3
"""Split Idleon websiteData.json into one file per top-level key."""

from __future__ import annotations

import argparse
import json
import os
import re
import sys
from collections.abc import Mapping
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
VENV_PYTHON = ROOT / ".venv/bin/python"
if VENV_PYTHON.exists() and Path(sys.executable) != VENV_PYTHON:
    os.execv(VENV_PYTHON, [str(VENV_PYTHON), *sys.argv])

DEFAULT_SOURCE = ROOT / "examples/websiteData.json"
DEFAULT_TYPES_SOURCE = ROOT / "examples/websiteData.d.json.ts"
DEFAULT_OUTPUT_DIR = ROOT / "examples/websiteData"
JSON_SUFFIX = ".json"
TYPE_SUFFIX = ".d.ts"
PYTHON_TYPE_SUFFIX = ".pyi"
MANIFEST_FILENAME = "_manifest.json"


def main() -> int:
    """Run the websiteData splitter."""
    parser = argparse.ArgumentParser(
        description="Split examples/websiteData.json into per-key JSON files.",
    )
    parser.add_argument(
        "--source",
        type=Path,
        default=DEFAULT_SOURCE,
        help="Source websiteData.json file.",
    )
    parser.add_argument(
        "--output-dir",
        type=Path,
        default=DEFAULT_OUTPUT_DIR,
        help="Directory to write split JSON files into.",
    )
    parser.add_argument(
        "--types-source",
        type=Path,
        default=DEFAULT_TYPES_SOURCE,
        help="Source websiteData TypeScript declaration file.",
    )
    args = parser.parse_args()

    data = _load_source(args.source)
    type_declarations = _load_type_declarations(args.types_source)
    written_paths = _write_split_files(data, type_declarations, args.output_dir)
    manifest_path = _write_manifest(
        data=data,
        type_declarations=type_declarations,
        output_dir=args.output_dir,
        source=args.source,
        types_source=args.types_source,
    )
    written_paths.add(manifest_path.resolve())
    _remove_stale_files(args.output_dir, written_paths)

    sys.stdout.write(
        f"Wrote {len(written_paths)} websiteData files to {args.output_dir}\n"
    )
    return 0


def _load_source(path: Path) -> Mapping[str, Any]:
    """Load a websiteData JSON object."""
    data = json.loads(path.read_text())
    if not isinstance(data, Mapping):
        msg = f"{path}: expected a top-level JSON object"
        raise TypeError(msg)
    return data


def _load_type_declarations(path: Path) -> Mapping[str, str]:
    """Load websiteData TypeScript declarations keyed by export name."""
    if not path.exists():
        return {}
    return _parse_type_declarations(path.read_text())


def _write_split_files(
    data: Mapping[str, Any],
    type_declarations: Mapping[str, str],
    output_dir: Path,
) -> set[Path]:
    """Write one JSON file per top-level key."""
    output_dir.mkdir(parents=True, exist_ok=True)
    written_paths: set[Path] = set()

    for key in sorted(data):
        filename = _safe_filename(key)
        json_path = output_dir / f"{filename}{JSON_SUFFIX}"
        json_path.write_text(json.dumps(data[key], indent=2, sort_keys=True) + "\n")
        written_paths.add(json_path.resolve())

        declaration = type_declarations.get(key)
        if declaration is not None:
            type_path = output_dir / f"{filename}{TYPE_SUFFIX}"
            type_path.write_text(_render_type_file(key, declaration))
            written_paths.add(type_path.resolve())

            python_type_path = output_dir / f"{filename}{PYTHON_TYPE_SUFFIX}"
            python_type_path.write_text(_render_python_type_file(key, declaration))
            written_paths.add(python_type_path.resolve())

    return written_paths


def _write_manifest(
    *,
    data: Mapping[str, Any],
    type_declarations: Mapping[str, str],
    output_dir: Path,
    source: Path,
    types_source: Path,
) -> Path:
    """Write a manifest connecting split JSON files and type declarations."""
    output_dir.mkdir(parents=True, exist_ok=True)
    files = {}
    for key in sorted(data):
        filename = _safe_filename(key)
        type_filename = (
            f"{filename}{TYPE_SUFFIX}" if key in type_declarations else None
        )
        python_type_filename = (
            f"{filename}{PYTHON_TYPE_SUFFIX}" if key in type_declarations else None
        )
        files[key] = {
            "json": f"{filename}{JSON_SUFFIX}",
            "type": type_filename,
            "python_type": python_type_filename,
        }

    manifest = {
        "source": str(source),
        "types_source": str(types_source) if types_source.exists() else None,
        "files": files,
    }
    path = output_dir / MANIFEST_FILENAME
    path.write_text(json.dumps(manifest, indent=2, sort_keys=True) + "\n")
    return path


def _remove_stale_files(output_dir: Path, written_paths: set[Path]) -> None:
    """Remove stale generated JSON/type files from the output directory."""
    stale_candidates = [
        *output_dir.glob(f"*{JSON_SUFFIX}"),
        *output_dir.glob(f"*{TYPE_SUFFIX}"),
        *output_dir.glob(f"*{PYTHON_TYPE_SUFFIX}"),
    ]
    for path in stale_candidates:
        if path.resolve() not in written_paths:
            path.unlink()


def _safe_filename(key: str) -> str:
    """Return a conservative filename for a websiteData key."""
    filename = re.sub(r"[^A-Za-z0-9_.-]+", "-", key).strip("-")
    return filename or "unknown"


def _parse_type_declarations(source: str) -> dict[str, str]:
    """Parse exported const type declarations from websiteData.d.json.ts."""
    declarations: dict[str, str] = {}
    cursor = 0
    marker = "export const "

    while True:
        start = source.find(marker, cursor)
        if start == -1:
            break

        name_start = start + len(marker)
        name_end = name_start
        while name_end < len(source) and (
            source[name_end].isalnum() or source[name_end] in {"_", "$"}
        ):
            name_end += 1

        name = source[name_start:name_end]
        colon = source.find(":", name_end)
        if not name or colon == -1:
            cursor = name_end
            continue

        type_start = colon + 1
        type_end = _find_declaration_end(source, type_start)
        if type_end == -1:
            cursor = type_start
            continue

        declarations[name] = source[type_start:type_end].strip()
        cursor = type_end + 1

    return declarations


def _find_declaration_end(source: str, start: int) -> int:
    """Find the semicolon ending a TypeScript const declaration."""
    brace_depth = 0
    bracket_depth = 0
    paren_depth = 0
    quote: str | None = None
    escaped = False

    for index in range(start, len(source)):
        character = source[index]

        if quote is not None:
            if escaped:
                escaped = False
            elif character == "\\":
                escaped = True
            elif character == quote:
                quote = None
            continue

        if character in {'"', "'", "`"}:
            quote = character
            continue
        if character == "{":
            brace_depth += 1
        elif character == "}":
            brace_depth -= 1
        elif character == "[":
            bracket_depth += 1
        elif character == "]":
            bracket_depth -= 1
        elif character == "(":
            paren_depth += 1
        elif character == ")":
            paren_depth -= 1
        elif (
            character == ";"
            and brace_depth == 0
            and bracket_depth == 0
            and paren_depth == 0
        ):
            return index

    return -1


def _render_type_file(key: str, declaration: str) -> str:
    """Render a split TypeScript declaration file."""
    type_name = f"WebsiteData{_pascal_case(key)}"
    return (
        "// Auto-generated from examples/websiteData.d.json.ts\n"
        "// Do not edit manually.\n\n"
        f"export type {type_name} = {declaration};\n\n"
        f"declare const data: {type_name};\n"
        "export default data;\n"
    )


def _render_python_type_file(key: str, declaration: str) -> str:
    """Render a split Python type stub file."""
    type_name = f"WebsiteData{_pascal_case(key)}"
    python_type = _typescript_to_python_type(declaration)
    return (
        "# Auto-generated from examples/websiteData.d.json.ts\n"
        "# Do not edit manually.\n\n"
        "from typing import Any, TypeAlias\n\n"
        f"{type_name}: TypeAlias = {python_type}\n"
    )


def _typescript_to_python_type(declaration: str) -> str:
    """Return a conservative Python type expression for a TypeScript type."""
    normalized = " ".join(declaration.strip().split())
    return _convert_typescript_type(normalized)


def _convert_typescript_type(value: str) -> str:
    """Convert common TypeScript type syntax into Python type syntax."""
    value = _strip_wrapping_parentheses(value.strip())

    array_depth = 0
    while value.endswith("[]"):
        array_depth += 1
        value = _strip_wrapping_parentheses(value[:-2].strip())

    union_parts = _split_top_level(value, "|")
    if len(union_parts) > 1:
        converted = " | ".join(
            _convert_typescript_type(part) for part in union_parts
        )
    elif value == "string":
        converted = "str"
    elif value == "number":
        converted = "int | float"
    elif value == "boolean":
        converted = "bool"
    elif value in {"any", "unknown"}:
        converted = "Any"
    elif value.startswith("Record<") and value.endswith(">"):
        converted = _convert_record_type(value)
    elif value.startswith("{") and value.endswith("}"):
        converted = "dict[str, Any]"
    elif value.startswith("[") and value.endswith("]"):
        converted = "tuple[Any, ...]"
    else:
        converted = "Any"

    for _ in range(array_depth):
        converted = f"list[{converted}]"
    return converted


def _convert_record_type(value: str) -> str:
    """Convert TypeScript Record<K, V> into dict[K, V]."""
    inner = value.removeprefix("Record<").removesuffix(">")
    parts = _split_top_level(inner, ",")
    if len(parts) != 2:
        return "dict[str, Any]"
    key_type = _convert_typescript_type(parts[0])
    value_type = _convert_typescript_type(parts[1])
    return f"dict[{key_type}, {value_type}]"


def _split_top_level(value: str, separator: str) -> list[str]:
    """Split a type expression by a separator outside nested syntax."""
    parts: list[str] = []
    start = 0
    angle_depth = 0
    brace_depth = 0
    bracket_depth = 0
    paren_depth = 0

    for index, character in enumerate(value):
        if character == "<":
            angle_depth += 1
        elif character == ">":
            angle_depth -= 1
        elif character == "{":
            brace_depth += 1
        elif character == "}":
            brace_depth -= 1
        elif character == "[":
            bracket_depth += 1
        elif character == "]":
            bracket_depth -= 1
        elif character == "(":
            paren_depth += 1
        elif character == ")":
            paren_depth -= 1
        elif (
            character == separator
            and angle_depth == 0
            and brace_depth == 0
            and bracket_depth == 0
            and paren_depth == 0
        ):
            parts.append(value[start:index].strip())
            start = index + 1

    if parts:
        parts.append(value[start:].strip())
        return parts
    return [value]


def _strip_wrapping_parentheses(value: str) -> str:
    """Remove one or more balanced wrapping parentheses."""
    while value.startswith("(") and value.endswith(")"):
        inner = value[1:-1].strip()
        if _split_top_level(inner, "|") == [inner]:
            value = inner
        else:
            break
    return value


def _pascal_case(value: str) -> str:
    """Return a PascalCase identifier suffix from a websiteData key."""
    parts = re.split(r"[^A-Za-z0-9]+", value)
    identifier = "".join(part[:1].upper() + part[1:] for part in parts if part)
    if not identifier:
        return "Unknown"
    if identifier[0].isdigit():
        return f"_{identifier}"
    return identifier


if __name__ == "__main__":
    raise SystemExit(main())
