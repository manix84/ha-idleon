#!/usr/bin/env python3
"""Split Idleon websiteData.json into one file per top-level key."""

from __future__ import annotations

import argparse
import json
import os
import re
import sys
from collections.abc import Mapping
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
VENV_PYTHON = ROOT / ".venv/bin/python"
if VENV_PYTHON.exists() and Path(sys.executable) != VENV_PYTHON:
    os.execv(VENV_PYTHON, [str(VENV_PYTHON), *sys.argv])

DEFAULT_SOURCE = ROOT / "examples/websiteData.json"
DEFAULT_OUTPUT_DIR = ROOT / "examples/websiteData"
GENERATED_SUFFIX = ".json"


def main() -> int:
    """Run the websiteData splitter."""
    parser = argparse.ArgumentParser(
        description="Split examples/websiteData.json into per-key JSON files.",
    )
    parser.add_argument(
        "--source",
        type=Path,
        default=DEFAULT_SOURCE,
        help="Source websiteData.json file.",
    )
    parser.add_argument(
        "--output-dir",
        type=Path,
        default=DEFAULT_OUTPUT_DIR,
        help="Directory to write split JSON files into.",
    )
    args = parser.parse_args()

    data = _load_source(args.source)
    written_paths = _write_split_files(data, args.output_dir)
    _remove_stale_files(args.output_dir, written_paths)

    sys.stdout.write(
        f"Wrote {len(written_paths)} websiteData files to {args.output_dir}\n"
    )
    return 0


def _load_source(path: Path) -> Mapping[str, Any]:
    """Load a websiteData JSON object."""
    data = json.loads(path.read_text())
    if not isinstance(data, Mapping):
        msg = f"{path}: expected a top-level JSON object"
        raise TypeError(msg)
    return data


def _write_split_files(data: Mapping[str, Any], output_dir: Path) -> set[Path]:
    """Write one JSON file per top-level key."""
    output_dir.mkdir(parents=True, exist_ok=True)
    written_paths: set[Path] = set()

    for key in sorted(data):
        path = output_dir / f"{_safe_filename(key)}{GENERATED_SUFFIX}"
        path.write_text(json.dumps(data[key], indent=2, sort_keys=True) + "\n")
        written_paths.add(path.resolve())

    return written_paths


def _remove_stale_files(output_dir: Path, written_paths: set[Path]) -> None:
    """Remove stale generated JSON files from the output directory."""
    for path in output_dir.glob(f"*{GENERATED_SUFFIX}"):
        if path.resolve() not in written_paths:
            path.unlink()


def _safe_filename(key: str) -> str:
    """Return a conservative filename for a websiteData key."""
    filename = re.sub(r"[^A-Za-z0-9_.-]+", "-", key).strip("-")
    return filename or "unknown"


if __name__ == "__main__":
    raise SystemExit(main())
