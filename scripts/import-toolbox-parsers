#!/usr/bin/env python3
"""Generate Python parser definitions from IdleonToolbox parser sources."""

from __future__ import annotations

import argparse
import json
import os
import re
import sys
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
VENV_PYTHON = ROOT / ".venv/bin/python"
if VENV_PYTHON.exists() and Path(sys.executable) != VENV_PYTHON:
    os.execv(VENV_PYTHON, [str(VENV_PYTHON), *sys.argv])

DEFAULT_SOURCE = Path("/Users/rob/Workspace/Personal/IdleonToolbox/parsers")
DEFAULT_OUTPUT = (
    ROOT
    / "custom_components/idleon/idleon_data/toolbox_parsers/generated_definitions.py"
)

WEBSITE_DATA_IMPORT_RE = re.compile(
    r"import\s*\{(?P<imports>[^}]+)\}\s*from\s*[\"']@website-data[\"']",
    re.DOTALL,
)
EXPORTED_FUNCTION_RE = re.compile(
    r"export\s+(?:const|function)\s+(?P<name>[A-Za-z0-9_]+)",
)
RAW_FIELD_RE = re.compile(
    r"(?:idleonData|char|character|rawCharactersData|accountData)"
    r"\?*\.\s*(?P<name>[A-Za-z0-9_]+)",
)


def main() -> int:
    """Generate parser definitions."""
    parser = argparse.ArgumentParser(
        description="Generate HA Idleon parser definitions from IdleonToolbox.",
    )
    parser.add_argument(
        "--source-dir",
        type=Path,
        default=DEFAULT_SOURCE,
        help="IdleonToolbox parsers directory.",
    )
    parser.add_argument(
        "--output",
        type=Path,
        default=DEFAULT_OUTPUT,
        help="Generated Python definitions module.",
    )
    args = parser.parse_args()

    definitions = _collect_definitions(args.source_dir)
    args.output.parent.mkdir(parents=True, exist_ok=True)
    args.output.write_text(_render_definitions(definitions))
    sys.stdout.write(f"Wrote {len(definitions)} parser definitions to {args.output}\n")
    return 0


def _collect_definitions(source_dir: Path) -> list[dict[str, Any]]:
    """Collect parser metadata from TypeScript source files."""
    if not source_dir.exists():
        msg = f"IdleonToolbox parser source directory not found: {source_dir}"
        raise FileNotFoundError(msg)

    definitions = []
    for path in sorted(source_dir.rglob("*.ts")):
        if path.name.endswith(".d.ts") or path.name.startswith("generated-"):
            continue
        text = path.read_text()
        source_path = path.relative_to(source_dir).as_posix()
        definitions.append(
            {
                "parser_id": _parser_id(path, source_dir),
                "source_path": source_path,
                "functions": _exported_functions(text),
                "website_data": _website_data_imports(text),
                "raw_fields": _raw_fields(text),
            }
        )
    return definitions


def _parser_id(path: Path, source_dir: Path) -> str:
    """Return a stable parser id from a TypeScript source path."""
    return path.relative_to(source_dir).with_suffix("").as_posix().replace("/", ".")


def _website_data_imports(text: str) -> tuple[str, ...]:
    """Return websiteData keys imported by a parser source."""
    imports: set[str] = set()
    for match in WEBSITE_DATA_IMPORT_RE.finditer(text):
        for part in match.group("imports").split(","):
            name = part.strip().split(" as ", maxsplit=1)[0].strip()
            if name:
                imports.add(name)
    return tuple(sorted(imports))


def _exported_functions(text: str) -> tuple[str, ...]:
    """Return exported parser/helper function names."""
    return tuple(sorted(set(EXPORTED_FUNCTION_RE.findall(text))))


def _raw_fields(text: str) -> tuple[str, ...]:
    """Return raw Idleon data fields referenced directly by parser source."""
    return tuple(sorted(set(RAW_FIELD_RE.findall(text))))


def _render_definitions(definitions: list[dict[str, Any]]) -> str:
    """Render parser definitions as an importable Python module."""
    json_text = json.dumps(definitions, indent=2, sort_keys=True)
    literal = f"({json_text[1:-1]},)"
    return (
        '"""Generated IdleonToolbox parser definitions."""\n\n'
        "from __future__ import annotations\n\n"
        "from typing import Any\n\n"
        "# Generated by scripts/import-toolbox-parsers.\n"
        "# Do not edit manually.\n"
        f"TOOLBOX_PARSER_DEFINITIONS: tuple[dict[str, Any], ...] = {literal}\n"
    )


if __name__ == "__main__":
    raise SystemExit(main())
