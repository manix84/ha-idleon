#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/_lib.sh
source "${SCRIPT_DIR}/_lib.sh"

cd "${ROOT_DIR}"
"$(python_bin)" - <<'PY'
from __future__ import annotations

from pathlib import Path

from PIL import Image

from scripts.release_asset_manifest import release_asset_paths

CANVAS_SIZE = (88, 88)
CONTENT_SIZE = (72, 72)
ASSET_ROOT = Path("custom_components/idleon/assets")

root = Path.cwd()
changed = 0


def _has_transparent_edge_padding(image: Image.Image) -> bool:
    """Return whether an image already has transparent edge padding."""
    alpha_bounds = image.getchannel("A").getbbox()
    if alpha_bounds is None:
        return True
    left, top, right, bottom = alpha_bounds
    margins = (left, top, image.width - right, image.height - bottom)
    return any(margin > 0 for margin in margins)


for relative_path in sorted(release_asset_paths(root)):
    if relative_path.suffix.lower() != ".png" or not relative_path.is_relative_to(
        ASSET_ROOT
    ):
        continue

    path = root / relative_path
    image = Image.open(path).convert("RGBA")
    if _has_transparent_edge_padding(image):
        continue

    original_size = image.size
    image.thumbnail(CONTENT_SIZE, Image.Resampling.LANCZOS)
    canvas = Image.new("RGBA", CANVAS_SIZE, (0, 0, 0, 0))
    x = (CANVAS_SIZE[0] - image.width) // 2
    y = (CANVAS_SIZE[1] - image.height) // 2
    canvas.alpha_composite(image, (x, y))
    canvas.save(path)
    changed += 1
    print(f"Padded {relative_path} from {original_size} to {CANVAS_SIZE}")

print(f"Padded {changed} entity picture assets.")
PY
