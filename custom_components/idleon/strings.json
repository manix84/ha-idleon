{
  "config": {
    "step": {
      "user": {
        "title": "Legends of Idleon",
        "description": "Choose how Home Assistant should connect to your read-only Idleon account data. Google and email are the primary login options. Apple and Steam are experimental.",
        "data": {
          "data_source_type": "Login or data source"
        }
      },
      "source": {
        "title": "Idleon login details",
        "description": "Enter the details needed for the selected Idleon connection. Credentials are used only to complete setup; Home Assistant stores the resulting refresh token for future read-only polling.",
        "data": {
          "idleon_email": "Idleon email address",
          "idleon_password": "Idleon password",
          "local_file_path": "Local JSON file path",
          "remote_url": "Remote JSON URL",
          "scan_interval": "Scan interval in seconds",
          "steam_openid_response_url": "Steam returned browser URL"
        }
      },
      "steam": {
        "title": "Authorize Steam login",
        "description": "Steam login is experimental. Choose a refresh interval, then submit to sign in with Steam. Home Assistant will open Steam and return here automatically after authorization.",
        "data": {
          "scan_interval": "Scan interval in seconds"
        }
      },
      "auth_provider": {
        "title": "Idleon Cloud login",
        "description": "Choose how Home Assistant should link your read-only Idleon cloud save.",
        "data": {
          "auth_provider": "Login provider",
          "scan_interval": "Scan interval in seconds"
        }
      },
      "google": {
        "title": "Authorize Google login",
        "description": "1. Open this Google login link:\n\n[{verification_url_complete}]({verification_url_complete})\n\n2. Confirm the code shown by Google matches this code:\n\n## {user_code}\n\n3. Finish signing in with the Google account used for Idleon.\n\n4. Return here and submit this form.\n\nIf the link does not prefill the code, open {verification_url} and enter the code manually. The code expires in about {expires_in} seconds."
      },
      "apple": {
        "title": "Authorize Apple login",
        "description": "Apple login is experimental.\n\n1. Open this Apple sign-in link:\n\n[{authorization_url}]({authorization_url})\n\n2. Finish signing in with the Apple ID used for Idleon.\n\n3. Return here and submit this form.\n\nApple returns to Idleon's own authorization endpoint, then Home Assistant checks whether that authorization has completed."
      }
    },
    "error": {
      "already_configured": "This data source is already configured.",
      "authorization_pending": "Authorization is not complete yet. Finish the browser sign-in, then submit again.",
      "auth_failed": "Idleon authentication failed. Check the account details and try again.",
      "cannot_connect": "Cannot connect to or read the data source.",
      "invalid_json": "The data source did not return valid JSON.",
      "invalid_schema": "The data source JSON does not look like Idleon account data.",
      "no_url_available": "Home Assistant needs an HTTPS external URL to receive the Steam sign-in callback.",
      "unknown": "Unexpected error"
    },
    "abort": {
      "already_configured": "This data source is already configured."
    }
  },
  "options": {
